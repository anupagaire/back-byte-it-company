generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Contact {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  company   String?
  service   String?
  message   String
  createdAt DateTime @default(now())
}

model Career {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  type        String
  location    String
  experience  String
  description String
  skills      String[]
  createdAt   DateTime @default(now())
}
model Job {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  location    String
  type        String   
  department  String
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  applications Application[]
}

model Application {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  jobId          String
  name           String
  email          String
  resumeUrl      String?
  resumePublicId String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("applications")
}
model AdminUser {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String   //hashed
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Service {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  shortDesc   String
  details     String
  image       String?  
  pricingConfig PricingConfig?
  color       String   @default("#69c8e4")
  icon        String   @default("Code2")
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

}
model Project {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  category  String
  tech      String[]
  desc      String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model TeamMember {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  role          String
  bio           String?
  photo         String?
  photoPublicId String?
  
  order         Int      @default(0)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PricingLead {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  email         String
  name          String?
  company       String?
  phone         String?

  // Service selection
  serviceType   String   // "web_app" | "mobile_app" | "cloud_cyber" | "digital_marketing"
  serviceLabel  String   // Human-readable label

  // Shared fields
  timeline      String   // "standard" | "express"
  estimatedPrice Float

  // Web / Mobile App fields
  pages         Int?
  hasAuth       Boolean? @default(false)
  hasPayments   Boolean? @default(false)
  backendType   String?  // "simple" | "complex"

  // Cloud / Cyber fields
  servers       Int?
  complianceLevel String? // "none" | "iso" | "soc2" | "both"
  auditFrequency  String? // "quarterly" | "biannual" | "annual"

  // Digital Marketing fields
  platforms     Int?
  adSpendBudget String?  // "under_1k" | "1k_5k" | "5k_20k" | "20k_plus"
  contentFreq   String?  // "weekly" | "biweekly" | "monthly"

  // Metadata
  status        String   @default("new")  // "new" | "contacted" | "converted" | "lost"
  notes         String?
  pdfGenerated  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("pricing_leads")
}

model PricingConfig {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  
  serviceId   String   @unique @db.ObjectId
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  serviceType   String   
  baseRate      Float

  // Per-unit cost (per page / per server / per platform)
  unitCost      Float

  // Shape: { standard: 1.0, express: 1.35, simple: 1.0, complex: 1.55, ... }
  multipliers   Json

  label         String   // "Web Application"
  unitLabel     String   // "pages" | "screens" | "servers" | "platforms"
  unitMax       Int      @default(20)

  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("pricing_configs")
}

model Testimonial {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  role      String
  image     String?
  message   String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}